#!/usr/bin/env python3
"""Authenticate, then relay MCP stdio bytes to Cage's host bridge."""

import os
import re
import select
import socket
import sys
import time

BUFSIZE = 65536
HANDSHAKE_PREFIX = b"CAGE-MCP/1 "
MAX_RESPONSE_BYTES = 16
NAME_PATTERN = re.compile(r"[A-Za-z0-9_-]+\Z")


def read_line(sock, maximum, timeout_seconds):
    data = bytearray()
    deadline = time.monotonic() + timeout_seconds
    while len(data) <= maximum:
        remaining = deadline - time.monotonic()
        if remaining <= 0:
            raise TimeoutError("authentication response timed out")
        sock.settimeout(remaining)
        chunk = sock.recv(1)
        if not chunk:
            break
        data.extend(chunk)
        if chunk == b"\n":
            break
    return bytes(data)


def main():
    if len(sys.argv) != 2 or not NAME_PATTERN.fullmatch(sys.argv[1]):
        print("mcp-relay: expected one valid server name", file=sys.stderr)
        return 64

    key = sys.argv[1].upper().replace("-", "_")
    try:
        host = os.environ["MCP_BRIDGE_HOST"]
        port = int(os.environ[f"MCP_BRIDGE_PORT_{key}"])
        token = os.environ["MCP_BRIDGE_TOKEN"]
    except (KeyError, ValueError):
        print("mcp-relay: bridge configuration is incomplete", file=sys.stderr)
        return 78
    if not re.fullmatch(r"[0-9a-f]{64}", token):
        print("mcp-relay: bridge authentication token is invalid", file=sys.stderr)
        return 78

    sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
    try:
        sock.settimeout(5.0)
        sock.connect((host, port))
        sock.sendall(HANDSHAKE_PREFIX + token.encode("ascii") + b"\n")
        if read_line(sock, MAX_RESPONSE_BYTES, 5.0) != b"OK\n":
            print("mcp-relay: bridge authentication failed", file=sys.stderr)
            return 77
        sock.settimeout(None)

        stdin_fd = sys.stdin.buffer.fileno()
        stdout = sys.stdout.buffer
        stdin_open = True
        while True:
            watch = [sock]
            if stdin_open:
                watch.append(stdin_fd)
            readable, _, _ = select.select(watch, [], [])
            for source in readable:
                if source is sock:
                    data = sock.recv(BUFSIZE)
                    if not data:
                        return 0
                    stdout.write(data)
                    stdout.flush()
                else:
                    data = os.read(stdin_fd, BUFSIZE)
                    if not data:
                        # Do not TCP-half-close: Docker Desktop can translate a
                        # half-close into a full close. MCP servers normally use
                        # framed messages rather than stdin EOF for completion.
                        stdin_open = False
                    else:
                        sock.sendall(data)
    except (BrokenPipeError, ConnectionResetError, OSError, TimeoutError) as exc:
        print(f"mcp-relay: bridge connection failed: {exc}", file=sys.stderr)
        return 74
    finally:
        sock.close()


if __name__ == "__main__":
    raise SystemExit(main())
