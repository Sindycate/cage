#!/bin/bash
set -euo pipefail

CAGE_VERSION="0.22.2"
CAGE_REGISTRY="ghcr.io/sindycate/cage"

HOST_CLAUDE_DIR="$HOME/.claude"
CAGE_CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/cage"
AWS_CREDS="$HOME/.aws/credentials"
# Resolve symlinks to find the real script directory
SOURCE="$0"
while [ -L "$SOURCE" ]; do
    DIR="$(cd "$(dirname "$SOURCE")" && pwd)"
    SOURCE="$(readlink "$SOURCE")"
    [[ "$SOURCE" != /* ]] && SOURCE="$DIR/$SOURCE"
done
SCRIPT_DIR="$(cd "$(dirname "$SOURCE")" && pwd)"
BUILD_DIR="$SCRIPT_DIR"

_trim_preserving_quotes() {
    local s="$1"
    s="${s#"${s%%[![:space:]]*}"}"
    s="${s%"${s##*[![:space:]]}"}"
    printf '%s' "$s"
}

# Top-level flags (before subcommand)
case "${1:-}" in
    --version|-V) echo "cage $CAGE_VERSION"; exit 0 ;;
    --help|-h)    set -- ;;  # clear args to trigger usage below
    setup|--setup)
        shift
        python3 "$SCRIPT_DIR/cage-config.py" --config "$CAGE_CONFIG_DIR/config.toml" init "$@"; exit $? ;;
    config|--config)
        shift
        python3 "$SCRIPT_DIR/cage-config.py" --config "$CAGE_CONFIG_DIR/config.toml" "$@"; exit $? ;;
    mcp|--mcp)
        shift
        python3 "$SCRIPT_DIR/cage-config.py" --config "$CAGE_CONFIG_DIR/config.toml" mcp "$@"; exit $? ;;
    netgate|--netgate)
        shift
        source "$SCRIPT_DIR/cage-netgate.sh"; exit $? ;;
    update|--update)
        shift
        # Resolve tool: explicit arg > default preset's tool > "claude"
        _upd_tool="${1:-}"
        if [ -z "$_upd_tool" ]; then
            if [ -f "$CAGE_CONFIG_DIR/config.toml" ]; then
                _upd_tool="$(python3 "$SCRIPT_DIR/cage-config.py" --config "$CAGE_CONFIG_DIR/config.toml" default-tool 2>/dev/null)" || true
            fi
            _upd_tool="${_upd_tool:-claude}"
        fi
        case "$_upd_tool" in
            claude)
                _upd_image="claude-code:${CAGE_VERSION}"
                _upd_registry="${CAGE_REGISTRY}/claude-code:${CAGE_VERSION}"
                _upd_dockerfile="Dockerfile"
                _upd_overlay="FROM claude-code:${CAGE_VERSION}
USER claude
RUN curl -fsSL https://claude.ai/install.sh | bash
USER root
RUN chmod -R a+rwX /home/claude"
                ;;
            codex)
                _upd_image="codex:${CAGE_VERSION}"
                _upd_registry="${CAGE_REGISTRY}/codex:${CAGE_VERSION}"
                _upd_dockerfile="Dockerfile.codex"
                _upd_overlay="FROM codex:${CAGE_VERSION}
ENV NPM_CONFIG_PREFIX=/home/codex/.npm-global
USER codex
RUN npm install -g @openai/codex@latest
USER root
RUN chown -R codex:codex /home/codex/.npm-global && chmod -R a+rwX /home/codex"
                ;;
            *)
                echo "Unknown tool: $_upd_tool (use 'claude' or 'codex')" >&2; exit 1 ;;
        esac
        # Ensure the base image exists (pull from registry, fall back to local build)
        if ! docker image inspect "$_upd_image" &>/dev/null; then
            echo "Base image $_upd_image not found locally."
            if docker pull "$_upd_registry" 2>/dev/null; then
                docker tag "$_upd_registry" "$_upd_image"
                echo "Pulled $_upd_registry"
            else
                echo "Pull failed or unavailable. Building locally..."
                docker build -t "$_upd_image" -f "$BUILD_DIR/$_upd_dockerfile" "$BUILD_DIR"
            fi
        fi
        echo "Updating $_upd_tool in $_upd_image (re-running installer only)..."
        printf '%s\n' "$_upd_overlay" | docker build --no-cache -t "$_upd_image" -t "${_upd_image%%:*}:latest" -f - "$BUILD_DIR"
        echo "Done. $_upd_image now has the latest $_upd_tool."
        exit 0 ;;
esac

# Subcommand detection: cage [claude|codex] [options] /path/to/repo [tool-args...]
CAGE_TOOL=""
if [[ "${1:-}" == "claude" || "${1:-}" == "codex" ]]; then
    CAGE_TOOL="$1"
    shift
fi

YOLO=0
REBUILD=0
NET_MODE=""  # empty = not explicitly set
CAGE_PRESET_FLAG=""
INTERACTIVE=0
EXTRA_MOUNT_SPECS=()   # entries are "ro<TAB><path>" / "rw<TAB><path>" from CLI flags

while [[ "${1:-}" == -* ]]; do
    case "$1" in
        -y|--yolo)
            YOLO=1
            shift
            ;;
        -i|--interactive)
            INTERACTIVE=1
            shift
            ;;
        --net)
            NET_MODE="${2:-gate}"
            shift 2
            ;;
        --net=*)
            NET_MODE="${1#--net=}"
            shift
            ;;
        --preset)
            CAGE_PRESET_FLAG="${2:-}"
            [ -z "$CAGE_PRESET_FLAG" ] && { echo "Missing preset name after --preset" >&2; exit 1; }
            [[ "$CAGE_PRESET_FLAG" =~ ^[a-zA-Z0-9_.-]+$ ]] || { echo "Invalid preset name: '$CAGE_PRESET_FLAG' (use only letters, digits, dots, hyphens, underscores)" >&2; exit 1; }
            shift 2
            ;;
        --preset=*)
            CAGE_PRESET_FLAG="${1#--preset=}"
            [[ "$CAGE_PRESET_FLAG" =~ ^[a-zA-Z0-9_.-]+$ ]] || { echo "Invalid preset name: '$CAGE_PRESET_FLAG' (use only letters, digits, dots, hyphens, underscores)" >&2; exit 1; }
            shift
            ;;
        --rebuild)
            REBUILD=1
            shift
            ;;
        --mount-ro)
            [ -n "${2:-}" ] || { echo "Missing path after --mount-ro" >&2; exit 1; }
            EXTRA_MOUNT_SPECS+=("ro"$'\t'"$2"); shift 2
            ;;
        --mount-ro=*)
            EXTRA_MOUNT_SPECS+=("ro"$'\t'"${1#--mount-ro=}"); shift
            ;;
        --mount-rw)
            [ -n "${2:-}" ] || { echo "Missing path after --mount-rw" >&2; exit 1; }
            EXTRA_MOUNT_SPECS+=("rw"$'\t'"$2"); shift 2
            ;;
        --mount-rw=*)
            EXTRA_MOUNT_SPECS+=("rw"$'\t'"${1#--mount-rw=}"); shift
            ;;
        *)
            echo "Unknown option: $1" >&2
            exit 1
            ;;
    esac
done

if [ "$INTERACTIVE" -eq 1 ] && [ -n "$CAGE_PRESET_FLAG" ]; then
    echo "ERROR: --interactive cannot be combined with --preset" >&2
    exit 1
fi

case "${NET_MODE:-open}" in
    open|gate|off) ;;
    *) echo "Invalid --net mode: $NET_MODE (use open, gate, or off)" >&2; exit 1 ;;
esac

if [ $# -lt 1 ]; then
    echo "Usage: cage [claude|codex] [-y|--yolo] [-i|--interactive] [--rebuild] [--preset NAME] [--net open|gate|off] [--mount-ro PATH] [--mount-rw PATH] /path/to/repo [tool-args...]"
    echo ""
    echo "Tools:"
    echo "  claude    Run Claude Code (default)"
    echo "  codex     Run OpenAI Codex CLI"
    echo ""
    echo "Commands:"
    echo "  setup                     Create starter ~/.config/cage/config.toml"
    echo "  config                    Manage central TOML configuration"
    echo "  config init               Create starter config.toml"
    echo "  config edit               Edit config.toml in \$EDITOR"
    echo "  config explain PATH       Explain the resolved launch configuration"
    echo "  config doctor PATH        Validate the resolved launch configuration"
    echo "  mcp login NAME PATH       Authenticate with an OAuth MCP server for a resolved Codex preset"
    echo "  mcp logout NAME PATH      Remove OAuth MCP authentication for a resolved Codex preset"
    echo "  netgate                    Manage domain allow/deny lists for --net gate"
    echo "  netgate list [PATH]        Show rules (defaults + global + project)"
    echo "  netgate allow DOMAIN       Allow a domain (project or --global)"
    echo "  netgate deny DOMAIN        Deny a domain (project)"
    echo "  netgate remove DOMAIN      Remove a decision (re-enables prompting)"
    echo "  netgate reset [PATH]       Delete all project decisions"
    echo "  update [claude|codex]      Refresh the tool binary only (fast; no full rebuild)"
    echo ""
    echo "Options:"
    echo "  --preset NAME     Use a central config preset (one-shot override)"
    echo "  -i, --interactive Choose an ad-hoc one-shot preset from configured blocks"
    echo "  -y, --yolo         Skip all permission prompts"
    echo "  --net open         Full network access (default without --yolo)"
    echo "  --net gate         Domain-gated network via proxy (default with --yolo)"
    echo "  --net off          No network access at all"
    echo "  --mount-ro PATH    Mount a host dir read-only at the same path (repeatable)"
    echo "  --mount-rw PATH    Mount a host dir read-write at the same path (repeatable)"
    echo "  --rebuild          Force local rebuild (get latest tool version)"
    echo "  --version, -V      Show version and exit"
    echo "  --help, -h         Show this help and exit"
    echo ""
    echo "Examples:"
    echo "  cage setup"
    echo "  cage config edit"
    echo "  cage mcp login dash0 ~/projects/myapp"
    echo "  cage ~/projects/myapp"
    echo "  cage --preset codex-company ~/projects/myapp"
    echo "  cage --interactive ~/projects/myapp"
    echo "  cage codex ~/projects/myapp"
    echo "  cage codex -y ~/projects/myapp"
    echo "  cage -y ~/projects/myapp"
    echo "  cage --net gate ~/projects/myapp"
    echo "  cage --mount-ro ~/code/shared-lib ~/projects/myapp"
    echo "  cage ~/projects/myapp --resume"
    echo "  cage ~/projects/myapp -p 'explain this codebase'"
    exit 1
fi

REPO_PATH="$(cd "$1" && pwd -P)"
shift

# Refuse to mount onto sensitive container paths. A host dir is bind-mounted at
# its real host path inside the container, so these would collide with the
# container's own filesystem. Returns 0 (success) when the path is reserved.
_is_reserved_mount_path() {
    case "$1" in
        /|/etc|/etc/*|/usr|/usr/*|/var|/var/*|/bin|/bin/*|/sbin|/sbin/*|/lib|/lib/*|/lib64|/lib64/*|/proc|/proc/*|/sys|/sys/*|/dev|/dev/*|/root|/root/*|/home/claude|/home/claude/*|/home/codex|/home/codex/*|/workspace|/workspace/*)
            return 0 ;;
    esac
    return 1
}

if _is_reserved_mount_path "$REPO_PATH"; then
    echo "ERROR: refusing to mount repo at '$REPO_PATH' — path conflicts with container filesystem" >&2
    exit 1
fi

_init_config_vars() {
    GIT_USER_NAME="" GIT_USER_EMAIL="" SSH_KEY="" SSH_HOST=""
    CLAUDE_AUTH="" AWS_PROFILE="" AWS_REGION="" EXTRA_ENV="" CODEX_COPY_AUTH="" HOST_CODEX_DIR="" HOST_AGENTS_DIR="" GH_AUTH="" GH_ACCOUNT=""
    MCP_SERVERS="" SKILL_MOUNTS="" HOST_COMMANDS="" SESSION_SYNC="" EXTRA_MOUNTS=""
    CAGE_PRESET="" CAGE_TOOL_RESOLVED="" CAGE_NET_MODE="" CAGE_REMOTE_MCP_SERVERS=""
}

_load_config() {
    _init_config_vars
    if [ ! -f "$CAGE_CONFIG_DIR/config.toml" ]; then
        echo "ERROR: central config not found at $CAGE_CONFIG_DIR/config.toml" >&2
        echo "Run: cage config init && cage config edit" >&2
        exit 1
    fi
    local resolve_args=(--config "$CAGE_CONFIG_DIR/config.toml")
    if [ "$INTERACTIVE" -eq 1 ]; then
        if [ ! -r /dev/tty ]; then
            echo "ERROR: interactive mode requires a TTY" >&2
            exit 1
        fi
        resolve_args+=(interactive-resolve --repo "$REPO_PATH")
        [ -n "${NET_MODE:-}" ] && resolve_args+=(--net "$NET_MODE")
        [ "$YOLO" -eq 1 ] && resolve_args+=(--yolo)
    else
        resolve_args+=(resolve --repo "$REPO_PATH")
        [ -n "${CAGE_PRESET_FLAG:-}" ] && resolve_args+=(--preset "$CAGE_PRESET_FLAG")
    fi
    [ -n "${CAGE_TOOL:-}" ] && resolve_args+=(--tool "$CAGE_TOOL")
    eval "$(python3 "$SCRIPT_DIR/cage-config.py" "${resolve_args[@]}")"
}

_load_config

# Resolve tool from the selected preset.
if [ -n "${CAGE_TOOL_RESOLVED:-}" ]; then
    CAGE_TOOL="$CAGE_TOOL_RESOLVED"
fi
if [ -z "$CAGE_TOOL" ]; then
    echo "ERROR: no tool resolved from central config preset" >&2
    exit 1
fi
case "$CAGE_TOOL" in
    claude|codex) ;;
    *) echo "Unknown tool: $CAGE_TOOL (use 'claude' or 'codex')" >&2; exit 1 ;;
esac

# Default NET_MODE: CLI flag > preset/defaults > yolo gate > open
if [ -z "$NET_MODE" ]; then
    if [ -n "${CAGE_NET_MODE:-}" ]; then
        NET_MODE="$CAGE_NET_MODE"
    elif [ "$YOLO" -eq 1 ]; then
        NET_MODE="gate"
    else
        NET_MODE="open"
    fi
fi

case "$NET_MODE" in
    open|gate|off) ;;
    *) echo "Invalid --net mode: $NET_MODE (use open, gate, or off)" >&2; exit 1 ;;
esac

# Tool-specific variables
case "$CAGE_TOOL" in
    claude)
        IMAGE="claude-code:${CAGE_VERSION}"
        REGISTRY_IMAGE="${CAGE_REGISTRY}/claude-code:${CAGE_VERSION}"
        CONTAINER_PREFIX="claude"
        VOLUME_PREFIX="claude-state"
        CONTAINER_HOME="/home/claude"
        TOOL_DISPLAY_NAME="Claude Code"
        DOCKERFILE="Dockerfile"
        ;;
    codex)
        IMAGE="codex:${CAGE_VERSION}"
        REGISTRY_IMAGE="${CAGE_REGISTRY}/codex:${CAGE_VERSION}"
        CONTAINER_PREFIX="codex"
        VOLUME_PREFIX="codex-state"
        CONTAINER_HOME="/home/codex"
        TOOL_DISPLAY_NAME="Codex CLI"
        DOCKERFILE="Dockerfile.codex"
        ;;
esac

# --- Extra named mounts -----------------------------------------------------
# Bind-mount additional host dirs at their same absolute host path (like the
# repo mount), read-only by default. Sources: resolved config + CLI flags.
EXTRA_MOUNT_ARGS=()
_EXTRA_MOUNT_SEEN=()

_add_extra_mount() {           # $1 = ro|rw, $2 = raw path
    local mode="$1" raw="$2" path real existing seen_mode seen_path
    path="${raw/#\~/$HOME}"
    if [ ! -d "$path" ]; then
        echo "WARNING: extra mount skipped — '$raw' is not an existing directory" >&2; return
    fi
    real="$(cd "$path" && pwd -P)" || { echo "WARNING: extra mount skipped — cannot resolve '$raw'" >&2; return; }
    if _is_reserved_mount_path "$real"; then
        echo "ERROR: refusing extra mount '$real' — path conflicts with container filesystem" >&2; exit 1
    fi
    if [ "$real" = "$REPO_PATH" ] || [[ "$real" == "$REPO_PATH"/* ]] || [[ "$REPO_PATH" == "$real"/* ]]; then
        echo "WARNING: extra mount skipped — '$real' overlaps the repo mount ($REPO_PATH)" >&2; return
    fi
    for existing in "${_EXTRA_MOUNT_SEEN[@]+"${_EXTRA_MOUNT_SEEN[@]}"}"; do
        seen_mode="${existing%%$'\t'*}"; seen_path="${existing#*$'\t'}"
        if [ "$seen_path" = "$real" ]; then
            [ "$seen_mode" != "$mode" ] && echo "WARNING: '$real' requested both ro and rw — keeping first ($seen_mode)" >&2
            return   # already mounted, first-wins
        fi
    done
    _EXTRA_MOUNT_SEEN+=("$mode"$'\t'"$real")
    if [ "$mode" = "rw" ]; then EXTRA_MOUNT_ARGS+=(-v "$real:$real")
    else EXTRA_MOUNT_ARGS+=(-v "$real:$real:ro"); fi
}

if [ -n "${EXTRA_MOUNTS:-}" ]; then    # newline-delimited resolved config
    while IFS= read -r line; do
        line="$(_trim_preserving_quotes "$line")"; [ -z "$line" ] && continue
        case "$line" in
            rw=*) _add_extra_mount rw "${line#rw=}" ;;
            ro=*) _add_extra_mount ro "${line#ro=}" ;;
            *)    _add_extra_mount ro "$line" ;;
        esac
    done <<< "${EXTRA_MOUNTS}"
fi
for spec in "${EXTRA_MOUNT_SPECS[@]+"${EXTRA_MOUNT_SPECS[@]}"}"; do   # CLI flags
    _add_extra_mount "${spec%%$'\t'*}" "${spec#*$'\t'}"
done

REPO_BASENAME="$(basename "$REPO_PATH")"
if command -v md5 &>/dev/null; then
    REPO_HASH="$(echo -n "$REPO_PATH" | md5 -q | cut -c1-8)"
else
    REPO_HASH="$(echo -n "$REPO_PATH" | md5sum | cut -c1-8)"
fi
CONTAINER_NAME="${CONTAINER_PREFIX}-${REPO_BASENAME}-${REPO_HASH}"
VOLUME_NAME="${VOLUME_PREFIX}-${REPO_BASENAME}-${REPO_HASH}"

# --- Parallel-instance / collision handling ---------------------------------
# A container with $CONTAINER_NAME already existing means another cage is
# already running for this repo (or crashed without --rm cleanup). Prompt the
# user: spawn parallel instance (suffix -2/-3/...), exec into the running one,
# remove a stopped leftover, or abort. Parallel instances share VOLUME_NAME by
# design — session JSONLs are per-UUID and the sync merge converges under
# concurrent writes; a separate volume per instance would mean fresh state
# every time, which defeats the point.
PARALLEL_LABEL=""

_existing_id="$(docker ps -a --filter "name=^${CONTAINER_NAME}$" --format '{{.ID}}')"
_running_id="$(docker ps    --filter "name=^${CONTAINER_NAME}$" --format '{{.ID}}')"

if [ -n "$_existing_id" ]; then
    if [ ! -r /dev/tty ]; then
        echo "ERROR: container '$CONTAINER_NAME' already exists and stdin is not a tty." >&2
        echo "Re-run interactively, or 'docker rm -f $CONTAINER_NAME' to clear." >&2
        exit 1
    fi

    # Pre-compute the next free suffix so the menu can show the actual name.
    _next_name=""
    _parallel_index=""
    for _i in 2 3 4 5 6 7 8 9; do
        _cand="${CONTAINER_NAME}-${_i}"
        if [ -z "$(docker ps -a --filter "name=^${_cand}$" --format '{{.ID}}')" ]; then
            _next_name="$_cand"; _parallel_index="$_i"; break
        fi
    done

    # Build menu dynamically: parallel option only when a free suffix exists,
    # exec only when the existing container is running, rm only when stopped.
    _actions=()
    _labels=()
    if [ -n "$_next_name" ]; then
        _actions+=(parallel); _labels+=("Start a parallel instance ($_next_name, shares state)")
    fi
    if [ -n "$_running_id" ]; then
        _actions+=(exec); _labels+=("Open a shell in the existing container")
    else
        _actions+=(rm); _labels+=("Remove the stopped container and start fresh")
    fi
    _actions+=(abort); _labels+=("Abort")

    _status_word="stopped"
    [ -n "$_running_id" ] && _status_word="running"

    {
        echo ""
        echo "A cage container already exists for this repo:"
        echo "  Name:   $CONTAINER_NAME"
        echo "  Status: $_status_word"
        echo ""
        echo "What would you like to do?"
        for _idx in "${!_labels[@]}"; do
            printf "  %d) %s\n" "$((_idx + 1))" "${_labels[$_idx]}"
        done
        echo ""
        printf "Choice [%d]: " "${#_actions[@]}"
    } >&2

    read -r _choice </dev/tty || _choice=""
    [ -z "$_choice" ] && _choice="${#_actions[@]}"

    if ! [[ "$_choice" =~ ^[0-9]+$ ]] || [ "$_choice" -lt 1 ] || [ "$_choice" -gt "${#_actions[@]}" ]; then
        echo "Invalid choice; aborting." >&2
        exit 1
    fi

    _action="${_actions[$((_choice - 1))]}"

    case "$_action" in
        parallel)
            CONTAINER_NAME="$_next_name"
            PARALLEL_LABEL=" (parallel #${_parallel_index})"
            ;;
        exec)
            echo "Attaching to existing container $CONTAINER_NAME (exec). Exit the shell to detach; the original cage session keeps running." >&2
            if docker exec "$_running_id" sh -c 'command -v bash >/dev/null 2>&1' 2>/dev/null; then
                exec docker exec -it "$_running_id" bash
            else
                exec docker exec -it "$_running_id" sh
            fi
            ;;
        rm)
            docker rm "$_existing_id" >/dev/null
            ;;
        abort)
            echo "Aborted." >&2
            exit 1
            ;;
    esac
fi

# Image acquisition: pull from registry, fall back to local build
if [ "$REBUILD" -eq 1 ]; then
    echo "Rebuilding $IMAGE from local Dockerfile..."
    docker build --no-cache -t "$IMAGE" -t "${IMAGE%%:*}:latest" -f "$BUILD_DIR/$DOCKERFILE" "$BUILD_DIR"
elif ! docker image inspect "$IMAGE" &>/dev/null; then
    echo "Image $IMAGE not found locally."
    if docker pull "$REGISTRY_IMAGE" 2>/dev/null; then
        docker tag "$REGISTRY_IMAGE" "$IMAGE"
        docker tag "$REGISTRY_IMAGE" "${IMAGE%%:*}:latest"
        echo "Pulled $REGISTRY_IMAGE"
    else
        echo "Pull failed or unavailable. Building locally..."
        docker build -t "$IMAGE" -t "${IMAGE%%:*}:latest" -f "$BUILD_DIR/$DOCKERFILE" "$BUILD_DIR"
    fi
fi

YOLO_LABEL=""
if [ "$YOLO" -eq 1 ]; then
    YOLO_LABEL=" [YOLO]"
fi

NET_LABEL=""
case "$NET_MODE" in
    gate) NET_LABEL=" [NET:GATED]" ;;
    off)  NET_LABEL=" [NET:OFF]" ;;
esac

# --- Netgate proxy lifecycle ---

PROXY_PID=""

cleanup_proxy() {
    if [ -n "$PROXY_PID" ] && kill -0 "$PROXY_PID" 2>/dev/null; then
        kill "$PROXY_PID" 2>/dev/null
        # Give proxy up to 2s to exit, then force-kill
        for _ in 1 2 3 4; do
            kill -0 "$PROXY_PID" 2>/dev/null || break
            sleep 0.5
        done
        kill -9 "$PROXY_PID" 2>/dev/null || true
        wait "$PROXY_PID" 2>/dev/null || true
    fi
    rm -f "${PROXY_LOG:-}"
}

PROXY_ARGS=()

if [ "$NET_MODE" = "gate" ]; then
    PROXY_OUTPUT=$(mktemp)
    PROXY_LOG=$(mktemp)
    python3 "$SCRIPT_DIR/netgate-proxy.py" \
        --project-hash "$REPO_HASH" \
        --container-name "$CONTAINER_NAME" \
        > "$PROXY_OUTPUT" 2>"$PROXY_LOG" &
    PROXY_PID=$!

    # Wait for proxy to be ready (up to 3 seconds)
    for _ in $(seq 1 30); do
        if grep -q "^READY" "$PROXY_OUTPUT" 2>/dev/null; then break; fi
        # Check if proxy already exited
        if ! kill -0 "$PROXY_PID" 2>/dev/null; then break; fi
        sleep 0.1
    done

    if ! grep -q "^READY" "$PROXY_OUTPUT" 2>/dev/null; then
        echo "ERROR: netgate proxy failed to start" >&2
        cat "$PROXY_LOG" >&2
        cleanup_proxy
        rm -f "$PROXY_OUTPUT" "$PROXY_LOG"
        exit 1
    fi

    PROXY_PORT=$(grep "^PORT=" "$PROXY_OUTPUT" | head -1 | cut -d= -f2)
    rm -f "$PROXY_OUTPUT"

    PROXY_URL="http://host.docker.internal:${PROXY_PORT}"
    NET_LABEL=" [NET:GATED :${PROXY_PORT}]"

    PROXY_ARGS=(
        --add-host host.docker.internal:host-gateway
        -e "HTTP_PROXY=${PROXY_URL}"
        -e "HTTPS_PROXY=${PROXY_URL}"
        -e "http_proxy=${PROXY_URL}"
        -e "https_proxy=${PROXY_URL}"
        -e "NO_PROXY=localhost,127.0.0.1"
        -e "no_proxy=localhost,127.0.0.1"
    )

    trap cleanup_proxy EXIT
fi

if [ "$NET_MODE" = "off" ]; then
    PROXY_ARGS=(--network none)
fi

# --- MCP bridge lifecycle ---

MCP_BRIDGE_PID=""
MCP_BRIDGE_ARGS=()
MCP_LABEL=""
MCP_JSON_BACKUP=""

cleanup_mcp_bridge() {
    # Restore .mcp.json if we patched it
    if [ -n "$MCP_JSON_BACKUP" ] && [ -f "$MCP_JSON_BACKUP" ]; then
        cp "$MCP_JSON_BACKUP" "$REPO_PATH/.mcp.json"
        rm -f "$MCP_JSON_BACKUP"
    fi
    if [ -n "$MCP_BRIDGE_PID" ] && kill -0 "$MCP_BRIDGE_PID" 2>/dev/null; then
        kill "$MCP_BRIDGE_PID" 2>/dev/null
        for _ in 1 2 3 4; do
            kill -0 "$MCP_BRIDGE_PID" 2>/dev/null || break
            sleep 0.5
        done
        kill -9 "$MCP_BRIDGE_PID" 2>/dev/null || true
        wait "$MCP_BRIDGE_PID" 2>/dev/null || true
    fi
    rm -f "${MCP_BRIDGE_LOG:-}"
}

if [ -n "${MCP_SERVERS:-}" ]; then
    if [ "$NET_MODE" = "off" ]; then
        echo "WARNING: stdio MCP servers ignored — network is disabled (--net off)" >&2
    else
        BRIDGE_ARGS=()
        while IFS= read -r line; do
            line="$(_trim_preserving_quotes "$line")"
            [ -z "$line" ] && continue
            srv_name="${line%%=*}"
            srv_cmd="${line#*=}"
            BRIDGE_ARGS+=(--server "$srv_name" "$srv_cmd")
        done <<< "${MCP_SERVERS}"

        if [ ${#BRIDGE_ARGS[@]} -gt 0 ]; then
            MCP_BRIDGE_OUTPUT=$(mktemp)
            MCP_BRIDGE_LOG=$(mktemp)
            python3 "$SCRIPT_DIR/mcp-bridge.py" "${BRIDGE_ARGS[@]}" \
                > "$MCP_BRIDGE_OUTPUT" 2>"$MCP_BRIDGE_LOG" &
            MCP_BRIDGE_PID=$!

            for _ in $(seq 1 30); do
                if grep -q "^READY" "$MCP_BRIDGE_OUTPUT" 2>/dev/null; then break; fi
                if ! kill -0 "$MCP_BRIDGE_PID" 2>/dev/null; then break; fi
                sleep 0.1
            done

            if ! grep -q "^READY" "$MCP_BRIDGE_OUTPUT" 2>/dev/null; then
                echo "ERROR: MCP bridge failed to start" >&2
                cat "$MCP_BRIDGE_LOG" >&2
                cleanup_mcp_bridge
                rm -f "$MCP_BRIDGE_OUTPUT" "$MCP_BRIDGE_LOG"
                exit 1
            fi

            # Build JSON map and env vars for container
            CAGE_MCP_JSON="{"
            _first=1
            while IFS= read -r sline; do
                srv_name=$(echo "$sline" | sed 's/^SERVER:\(.*\)=PORT:.*/\1/')
                srv_port=$(echo "$sline" | sed 's/.*=PORT://')
                upper_name=$(echo "$srv_name" | tr '[:lower:]-' '[:upper:]_')
                MCP_BRIDGE_ARGS+=(-e "MCP_BRIDGE_PORT_${upper_name}=${srv_port}")
                [ "$_first" -eq 1 ] && _first=0 || CAGE_MCP_JSON+=","
                CAGE_MCP_JSON+="\"${srv_name}\":${srv_port}"
            done < <(grep "^SERVER:" "$MCP_BRIDGE_OUTPUT")
            CAGE_MCP_JSON+="}"

            MCP_BRIDGE_ARGS+=(
                -e "MCP_BRIDGE_HOST=host.docker.internal"
                -e "CAGE_MCP_SERVERS=${CAGE_MCP_JSON}"
            )

            # Add host.docker.internal if netgate hasn't already
            if [ "$NET_MODE" != "gate" ]; then
                MCP_BRIDGE_ARGS+=(--add-host host.docker.internal:host-gateway)
            fi

            # Patch .mcp.json in the repo if it defines any bridged servers
            if [ -f "$REPO_PATH/.mcp.json" ]; then
                MCP_JSON_BACKUP=$(mktemp)
                cp "$REPO_PATH/.mcp.json" "$MCP_JSON_BACKUP"
                python3 -c "
import json, sys
with open('$REPO_PATH/.mcp.json') as f:
    cfg = json.load(f)
bridged = set(sys.argv[1:])
changed = False
for name in list(cfg.get('mcpServers', {})):
    if name in bridged:
        cfg['mcpServers'][name] = {'type': 'stdio', 'command': 'mcp-relay', 'args': [name]}
        changed = True
if changed:
    with open('$REPO_PATH/.mcp.json', 'w') as f:
        json.dump(cfg, f, indent=4)
" $(grep "^SERVER:" "$MCP_BRIDGE_OUTPUT" | sed 's/^SERVER:\(.*\)=PORT:.*/\1/') 2>/dev/null || true
            fi

            rm -f "$MCP_BRIDGE_OUTPUT"

            MCP_LABEL=" [MCP]"

            trap 'cleanup_mcp_bridge; cleanup_proxy' EXIT
        fi
    fi
fi

if [ -n "${CAGE_REMOTE_MCP_SERVERS:-}" ] && [ -z "$MCP_LABEL" ]; then
    MCP_LABEL=" [MCP]"
fi

# --- Host command bridge lifecycle ------------------------------------------
# For each resolved host command entry "name=host cmd", run a host-side TCP listener
# (host-cmd-bridge.py) that spawns the host command on each container
# connection and relays stdio. A shim written into /usr/local/bin/<name> in
# the container calls host-cmd-relay, which connects to this listener.
# Use case: token-refresh commands (e.g. ztoken) that need host keychain
# access but are referenced by tools inside the container.

HOST_CMD_BRIDGE_PID=""
HOST_CMD_BRIDGE_ARGS=()
HOST_CMD_LABEL=""
HOST_CMD_NAMES=""

cleanup_host_cmd_bridge() {
    if [ -n "$HOST_CMD_BRIDGE_PID" ] && kill -0 "$HOST_CMD_BRIDGE_PID" 2>/dev/null; then
        kill "$HOST_CMD_BRIDGE_PID" 2>/dev/null
        for _ in 1 2 3 4; do
            kill -0 "$HOST_CMD_BRIDGE_PID" 2>/dev/null || break
            sleep 0.5
        done
        kill -9 "$HOST_CMD_BRIDGE_PID" 2>/dev/null || true
        wait "$HOST_CMD_BRIDGE_PID" 2>/dev/null || true
    fi
    rm -f "${HOST_CMD_BRIDGE_LOG:-}"
}

if [ -n "${HOST_COMMANDS:-}" ]; then
    if [ "$NET_MODE" = "off" ]; then
        echo "WARNING: host commands ignored — network is disabled (--net off)" >&2
    else
        HOST_CMD_ARGS=()
        while IFS= read -r line; do
            line="$(_trim_preserving_quotes "$line")"
            [ -z "$line" ] && continue
            cmd_name="${line%%=*}"
            cmd_line="${line#*=}"
            HOST_CMD_ARGS+=(--command "$cmd_name" "$cmd_line")
            HOST_CMD_NAMES="${HOST_CMD_NAMES:+$HOST_CMD_NAMES }$cmd_name"
        done <<< "${HOST_COMMANDS}"

        if [ ${#HOST_CMD_ARGS[@]} -gt 0 ]; then
            HOST_CMD_BRIDGE_OUTPUT=$(mktemp)
            HOST_CMD_BRIDGE_LOG=$(mktemp)
            python3 "$SCRIPT_DIR/host-cmd-bridge.py" "${HOST_CMD_ARGS[@]}" \
                > "$HOST_CMD_BRIDGE_OUTPUT" 2>"$HOST_CMD_BRIDGE_LOG" &
            HOST_CMD_BRIDGE_PID=$!

            for _ in $(seq 1 30); do
                if grep -q "^READY" "$HOST_CMD_BRIDGE_OUTPUT" 2>/dev/null; then break; fi
                if ! kill -0 "$HOST_CMD_BRIDGE_PID" 2>/dev/null; then break; fi
                sleep 0.1
            done

            if ! grep -q "^READY" "$HOST_CMD_BRIDGE_OUTPUT" 2>/dev/null; then
                echo "ERROR: host command bridge failed to start" >&2
                cat "$HOST_CMD_BRIDGE_LOG" >&2
                cleanup_host_cmd_bridge
                rm -f "$HOST_CMD_BRIDGE_OUTPUT" "$HOST_CMD_BRIDGE_LOG"
                exit 1
            fi

            while IFS= read -r cline; do
                cmd_name=$(echo "$cline" | sed 's/^COMMAND:\(.*\)=PORT:.*/\1/')
                cmd_port=$(echo "$cline" | sed 's/.*=PORT://')
                upper_name=$(echo "$cmd_name" | tr '[:lower:]-' '[:upper:]_')
                HOST_CMD_BRIDGE_ARGS+=(-e "HOST_CMD_BRIDGE_PORT_${upper_name}=${cmd_port}")
            done < <(grep "^COMMAND:" "$HOST_CMD_BRIDGE_OUTPUT")

            HOST_CMD_BRIDGE_ARGS+=(
                -e "HOST_CMD_BRIDGE_HOST=host.docker.internal"
                -e "CAGE_HOST_COMMANDS=${HOST_CMD_NAMES}"
            )

            # Add host.docker.internal if neither netgate nor MCP bridge already did
            if [ "$NET_MODE" != "gate" ] && [ -z "$MCP_BRIDGE_PID" ]; then
                HOST_CMD_BRIDGE_ARGS+=(--add-host host.docker.internal:host-gateway)
            fi

            rm -f "$HOST_CMD_BRIDGE_OUTPUT"

            HOST_CMD_LABEL=" [HOST-CMD]"

            trap 'cleanup_host_cmd_bridge; cleanup_mcp_bridge; cleanup_proxy' EXIT
        fi
    fi
fi

# --- Session history sync (Claude only) -------------------------------------
# Two-part flow, always run for Claude (migration is unconditional since the
# mount path moved; host-sync is gated by SESSION_SYNC):
#
#   1. Legacy-session migration (in-volume only) — rewrites sessions that were
#      recorded under the old /workspace/<name>/ cwd so they resume under the
#      new host-path cwd. Always runs to avoid stranding history on upgrade.
#   2. Host<->volume sync — bidirectional copy of the single project's JSONL
#      files between ~/.claude/projects/-<slug>/ and the per-repo Docker
#      volume. All host-side writes happen here, in the host cage script
#      running as the host user. The container's read-only /host-claude mount
#      is unchanged.
SESSION_SLUG=""
if [ "$CAGE_TOOL" = "claude" ]; then
    SESSION_SLUG="$(echo -n "$REPO_PATH" | tr '/' '-')"
    HOST_PROJ_DIR="$HOST_CLAUDE_DIR/projects/$SESSION_SLUG"
    SESSION_SYNC_ENABLED="${SESSION_SYNC:-1}"

    docker volume create "$VOLUME_NAME" >/dev/null

    # -v for the host dir is added only when the dir exists, to avoid docker
    # auto-creating it as root on the host.
    SYNC_IN_MOUNTS=(-v "$VOLUME_NAME:/vol")
    if [ "$SESSION_SYNC_ENABLED" = "1" ] && [ -d "$HOST_PROJ_DIR" ]; then
        SYNC_IN_MOUNTS+=(-v "$HOST_PROJ_DIR:/src:ro")
    fi
    docker run --rm \
        "${SYNC_IN_MOUNTS[@]}" \
        -e "SLUG=$SESSION_SLUG" \
        -e "REPO_PATH=$REPO_PATH" \
        -e "HOST_UID=$(id -u)" -e "HOST_GID=$(id -g)" \
        alpine:3 sh -c '
            DST="/vol/projects/$SLUG"
            mkdir -p "$DST"

            # Merge one file into $DST. Rules:
            #   *.jsonl → size-based (append-only: larger wins; equal size syncs mtime
            #             from src, which also repairs mtimes stamped "now" by v0.8.0).
            #   other   → mtime-based (newer wins). Memory .md, .meta.json, tool-results.
            sync_one() {
                src="$1"; dst="$2"; rel="$3"
                mkdir -p "$(dirname "$dst")"
                if [ ! -e "$dst" ]; then
                    cp -p "$src" "$dst"
                    return
                fi
                case "$rel" in
                    *.jsonl)
                        ss=$(stat -c%s "$src"); ds=$(stat -c%s "$dst")
                        if [ "$ss" -gt "$ds" ]; then
                            cp -p "$src" "$dst.tmp" && mv "$dst.tmp" "$dst"
                        elif [ "$ss" = "$ds" ]; then
                            touch -r "$src" "$dst"
                        fi
                        ;;
                    *)
                        sm=$(stat -c%Y "$src"); dm=$(stat -c%Y "$dst")
                        if [ "$sm" -gt "$dm" ]; then
                            cp -p "$src" "$dst.tmp" && mv "$dst.tmp" "$dst"
                        fi
                        ;;
                esac
            }

            # 1) Host → volume (whole subtree).
            if [ -d /src ]; then
                cd /src && find . -type f | while read rel; do
                    rel="${rel#./}"
                    sync_one "/src/$rel" "$DST/$rel" "$rel"
                done
            fi

            # 2) Legacy slug → new slug. Runs after host sync so legacy mtimes are
            #    authoritative for legacy-only files (and repairs stamped-now mtimes).
            #    For .jsonl: rewrite embedded "cwd":"/workspace/..." so Claude --resume matches.
            for old in /vol/projects/-workspace-*; do
                [ -d "$old" ] || continue
                cd "$old" && find . -type f | while read rel; do
                    rel="${rel#./}"
                    src="$old/$rel"; dst="$DST/$rel"
                    mkdir -p "$(dirname "$dst")"
                    case "$rel" in
                        *.jsonl)
                            if [ ! -e "$dst" ]; then
                                sed "s|\"cwd\":\"/workspace/[^\"]*\"|\"cwd\":\"$REPO_PATH\"|g" "$src" > "$dst.tmp" \
                                    && mv "$dst.tmp" "$dst" \
                                    && touch -r "$src" "$dst"
                            else
                                # Already migrated — legacy mtime is authoritative.
                                touch -r "$src" "$dst"
                            fi
                            ;;
                        *)
                            if [ ! -e "$dst" ]; then
                                cp -p "$src" "$dst"
                            else
                                sm=$(stat -c%Y "$src"); dm=$(stat -c%Y "$dst")
                                if [ "$sm" -gt "$dm" ]; then
                                    cp -p "$src" "$dst.tmp" && mv "$dst.tmp" "$dst"
                                fi
                            fi
                            ;;
                    esac
                done
            done

            chown -R "$HOST_UID:$HOST_GID" "$DST"
        ' >/dev/null 2>&1 || true

    # If host-sync is disabled, don't register sync-out cleanup.
    [ "$SESSION_SYNC_ENABLED" = "1" ] || SESSION_SLUG=""
fi

cleanup_session_sync() {
    [ -z "$SESSION_SLUG" ] && return 0
    mkdir -p "$HOST_CLAUDE_DIR/projects/$SESSION_SLUG"
    # Sync-out: copy volume JSONLs back to host, size-guarded (append-only JSONL → larger = newer).
    # Runs as host UID:GID so files land with correct ownership.
    docker run --rm \
        --user "$(id -u):$(id -g)" \
        -v "$VOLUME_NAME:/vol:ro" \
        -v "$HOST_CLAUDE_DIR/projects/$SESSION_SLUG:/dst" \
        -e "SLUG=$SESSION_SLUG" \
        alpine:3 sh -c '
            SRC="/vol/projects/$SLUG"
            [ -d "$SRC" ] || exit 0
            cd "$SRC" && find . -type f | while read rel; do
                rel="${rel#./}"
                src="$SRC/$rel"; dst="/dst/$rel"
                mkdir -p "$(dirname "$dst")"
                if [ ! -e "$dst" ]; then
                    cp -p "$src" "$dst.tmp" && mv "$dst.tmp" "$dst"
                    continue
                fi
                case "$rel" in
                    *.jsonl)
                        ss=$(stat -c%s "$src"); ds=$(stat -c%s "$dst")
                        if [ "$ss" -gt "$ds" ]; then
                            cp -p "$src" "$dst.tmp" && mv "$dst.tmp" "$dst"
                        elif [ "$ss" = "$ds" ]; then
                            # Content matches: propagate corrected mtime from volume to host.
                            touch -r "$src" "$dst"
                        fi
                        ;;
                    *)
                        sm=$(stat -c%Y "$src"); dm=$(stat -c%Y "$dst")
                        if [ "$sm" -gt "$dm" ]; then
                            cp -p "$src" "$dst.tmp" && mv "$dst.tmp" "$dst"
                        fi
                        ;;
                esac
            done
        ' >/dev/null 2>&1 || true
}

echo "=== ${TOOL_DISPLAY_NAME} Container${YOLO_LABEL}${NET_LABEL}${MCP_LABEL}${HOST_CMD_LABEL} ==="
echo "  Repo:      $REPO_PATH"
[ -n "${CAGE_PRESET:-}" ] && echo "  Preset:    $CAGE_PRESET"
echo "  Container: $CONTAINER_NAME${PARALLEL_LABEL}"
echo "  Volume:    $VOLUME_NAME"
echo "=============================="

# Shared Docker args
DOCKER_ARGS=(
    --rm
    -it
    --name "$CONTAINER_NAME"
    --hostname "$CONTAINER_NAME"
    --cap-drop ALL
    --cap-add CHOWN
    --cap-add DAC_OVERRIDE
    --cap-add SETGID
    --cap-add SETUID
    --tmpfs /tmp
    --tmpfs /run
    -v "$REPO_PATH:$REPO_PATH"
    -e "WORKSPACE_DIR=$REPO_PATH"
    -e "HOST_UID=$(id -u)"
    -e "HOST_GID=$(id -g)"
)

# Forward terminal capability hints from host (cosmetic only)
if [ -n "${TERM:-}" ]; then
    DOCKER_ARGS+=(-e "TERM=$TERM")
fi
if [ -n "${COLORTERM:-}" ]; then
    DOCKER_ARGS+=(-e "COLORTERM=$COLORTERM")
fi

# Tool-specific Docker args
case "$CAGE_TOOL" in
    claude)
        DOCKER_ARGS+=(
            --security-opt apparmor=unconfined
            --security-opt seccomp=unconfined
            -v "$VOLUME_NAME:${CONTAINER_HOME}/.claude"
            -v "$HOST_CLAUDE_DIR:/host-claude:ro"
        )
        # Host ~/.claude.json holds user/local-scope MCP servers (the file Claude
        # actually reads MCP config from — settings.json does not carry mcpServers).
        # Mount read-only at a separate path; the entrypoint copies ONLY the
        # mcpServers key into the writable volume copy, never writing back here.
        if [ -f "$HOME/.claude.json" ]; then
            DOCKER_ARGS+=(-v "$HOME/.claude.json:/host-claude-json:ro")
        fi
        # ccstatusline keeps its own config separate from settings.json
        CCSL_HOST_PATH="$HOME/.config/ccstatusline"
        if [ -d "$CCSL_HOST_PATH" ]; then
            DOCKER_ARGS+=(-v "$CCSL_HOST_PATH:/host-ccstatusline:ro")
        fi
        # Auth: bedrock (default) or api-key
        case "${CLAUDE_AUTH:-bedrock}" in
            bedrock)
                DOCKER_ARGS+=(
                    -e "CLAUDE_CODE_USE_BEDROCK=1"
                    -e "AWS_PROFILE=${AWS_PROFILE:-}"
                    -e "AWS_REGION=${AWS_REGION:-}"
                    -v "$AWS_CREDS:${CONTAINER_HOME}/.aws/credentials:ro"
                )
                ;;
            api-key)
                if [ -z "${ANTHROPIC_API_KEY:-}" ]; then
                    echo "ERROR: CLAUDE_AUTH=api-key but ANTHROPIC_API_KEY is not set" >&2
                    exit 1
                fi
                DOCKER_ARGS+=(-e "ANTHROPIC_API_KEY=$ANTHROPIC_API_KEY")
                ;;
            *)
                echo "Invalid CLAUDE_AUTH: $CLAUDE_AUTH (use 'bedrock' or 'api-key')" >&2
                exit 1
                ;;
        esac
        ;;
    codex)
        DOCKER_ARGS+=(
            # Codex CLI uses bubblewrap to sandbox tool calls (apply_patch, rg, etc).
            # bwrap needs user namespaces, which Docker's seccomp/AppArmor block by default.
            # The container itself is the security boundary, so this is safe to relax.
            --security-opt apparmor=unconfined
            --security-opt seccomp=unconfined
            -v "$VOLUME_NAME:${CONTAINER_HOME}/.codex"
        )
        CODEX_HOST_PATH="${HOST_CODEX_DIR:-$HOME/.codex}"
        CODEX_HOST_PATH="${CODEX_HOST_PATH/#\~/$HOME}"
        if [ -d "$CODEX_HOST_PATH" ]; then
            DOCKER_ARGS+=(-v "$CODEX_HOST_PATH:/host-codex:ro")
        fi
        if [ -n "${SKILL_MOUNTS:-}" ]; then
            CAGE_SKILL_NAMES=()
            while IFS= read -r line; do
                [ -z "$line" ] && continue
                skill_name="${line%%=*}"
                skill_path="${line#*=}"
                if [ ! -d "$skill_path" ]; then
                    echo "ERROR: selected skill '$skill_name' directory does not exist: $skill_path" >&2
                    exit 1
                fi
                if [ ! -f "$skill_path/SKILL.md" ]; then
                    echo "ERROR: selected skill '$skill_name' is missing SKILL.md: $skill_path" >&2
                    exit 1
                fi
                DOCKER_ARGS+=(-v "$skill_path:/host-agent-skills/$skill_name:ro")
                CAGE_SKILL_NAMES+=("$skill_name")
            done <<< "${SKILL_MOUNTS}"
            if [ ${#CAGE_SKILL_NAMES[@]} -gt 0 ]; then
                DOCKER_ARGS+=(-e "CAGE_SKILL_NAMES=${CAGE_SKILL_NAMES[*]}")
            fi
        else
            AGENTS_HOST_PATH="${HOST_AGENTS_DIR:-$HOME/.agents}"
            AGENTS_HOST_PATH="${AGENTS_HOST_PATH/#\~/$HOME}"
            if [ -d "$AGENTS_HOST_PATH" ]; then
                DOCKER_ARGS+=(-v "$AGENTS_HOST_PATH:/host-agents:ro")
            fi
        fi
        if [ -n "${OPENAI_API_KEY:-}" ]; then
            DOCKER_ARGS+=(-e "OPENAI_API_KEY=$OPENAI_API_KEY")
        fi
        if [ "${CODEX_COPY_AUTH:-1}" = "0" ]; then
            DOCKER_ARGS+=(-e "CODEX_COPY_AUTH=0")
        fi
        ;;
esac

# Git/SSH mounts and env vars from resolved config
if [ -n "$GIT_USER_NAME" ]; then
    DOCKER_ARGS+=(-e "GIT_USER_NAME=$GIT_USER_NAME")
fi
if [ -n "$GIT_USER_EMAIL" ]; then
    DOCKER_ARGS+=(-e "GIT_USER_EMAIL=$GIT_USER_EMAIL")
fi
if [ -n "$SSH_KEY" ]; then
    SSH_KEY_PATH="${SSH_KEY/#\~/$HOME}"
    if [ -f "$SSH_KEY_PATH" ]; then
        DOCKER_ARGS+=(-v "$SSH_KEY_PATH:${CONTAINER_HOME}/.ssh/id:ro")
        DOCKER_ARGS+=(-e 'GIT_SSH_COMMAND=ssh -i '"${CONTAINER_HOME}"'/.ssh/id -o IdentitiesOnly=yes -o StrictHostKeyChecking=accept-new')
        [ -f "$HOME/.ssh/known_hosts" ] && DOCKER_ARGS+=(-v "$HOME/.ssh/known_hosts:${CONTAINER_HOME}/.ssh/known_hosts:ro")
    fi
fi
if [ -n "$SSH_HOST" ]; then
    DOCKER_ARGS+=(-e "SSH_HOST=$SSH_HOST")
fi

# Extra env vars from resolved config
for varname in $EXTRA_ENV; do
    if [ -n "${!varname:-}" ]; then
        DOCKER_ARGS+=(-e "$varname=${!varname}")
    fi
done

if [ -n "${CAGE_REMOTE_MCP_SERVERS:-}" ]; then
    DOCKER_ARGS+=(-e "CAGE_REMOTE_MCP_SERVERS=$CAGE_REMOTE_MCP_SERVERS")
fi

# GitHub CLI auth from resolved config
if [ "${GH_AUTH:-0}" = "1" ]; then
    HOST_GH_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/gh"
    if [ -d "$HOST_GH_DIR" ]; then
        DOCKER_ARGS+=(-v "$HOST_GH_DIR:/host-gh:ro")
    fi

    # Auto-extract token from host gh if no explicit token
    if [ -z "${GH_TOKEN:-}" ] && [ -z "${GITHUB_TOKEN:-}" ]; then
        if command -v gh &>/dev/null; then
            if [ -n "${GH_ACCOUNT:-}" ]; then
                GH_TOKEN="$(gh auth token -u "$GH_ACCOUNT" 2>/dev/null)" || true
            else
                GH_TOKEN="$(gh auth token 2>/dev/null)" || true
            fi
        fi
    fi

    if [ -n "${GH_TOKEN:-}" ]; then
        DOCKER_ARGS+=(-e "GH_TOKEN=$GH_TOKEN")
    elif [ -n "${GITHUB_TOKEN:-}" ]; then
        DOCKER_ARGS+=(-e "GH_TOKEN=$GITHUB_TOKEN")
    fi
fi

[[ ${#PROXY_ARGS[@]} -gt 0 ]] && DOCKER_ARGS+=("${PROXY_ARGS[@]}")
[[ ${#MCP_BRIDGE_ARGS[@]} -gt 0 ]] && DOCKER_ARGS+=("${MCP_BRIDGE_ARGS[@]}")
[[ ${#HOST_CMD_BRIDGE_ARGS[@]} -gt 0 ]] && DOCKER_ARGS+=("${HOST_CMD_BRIDGE_ARGS[@]}")
[[ ${#EXTRA_MOUNT_ARGS[@]} -gt 0 ]] && DOCKER_ARGS+=("${EXTRA_MOUNT_ARGS[@]}")

TOOL_ARGS=()
if [ "$YOLO" -eq 1 ]; then
    case "$CAGE_TOOL" in
        claude) TOOL_ARGS+=(--dangerously-skip-permissions) ;;
        codex)  TOOL_ARGS+=(--yolo)
                DOCKER_ARGS+=(-e "CAGE_YOLO=1") ;;
    esac
fi

if [ "$NET_MODE" = "gate" ] || [ -n "$MCP_BRIDGE_PID" ] || [ -n "$HOST_CMD_BRIDGE_PID" ] || [ -n "$SESSION_SLUG" ]; then
    # Cannot use exec: need cleanup traps to run via trap EXIT
    trap 'cleanup_session_sync; cleanup_host_cmd_bridge; cleanup_mcp_bridge; cleanup_proxy' EXIT
    docker run "${DOCKER_ARGS[@]}" "$IMAGE" ${TOOL_ARGS[@]+"${TOOL_ARGS[@]}"} "$@"
else
    exec docker run "${DOCKER_ARGS[@]}" "$IMAGE" ${TOOL_ARGS[@]+"${TOOL_ARGS[@]}"} "$@"
fi
