MCP_BRIDGE_PID=""
MCP_BRIDGE_ARGS=()
MCP_LABEL=""
MCP_PROJECT_CONFIG=""
MCP_BRIDGE_TOKEN=""

cleanup_mcp_bridge() {
    # The generated project MCP config is mounted read-only inside the
    # container and never written into the host repository.
    if [ -n "${MCP_PROJECT_CONFIG:-}" ]; then
        rm -f "$MCP_PROJECT_CONFIG"
