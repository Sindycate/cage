            sleep 0.5
        done
        kill -9 "$MCP_BRIDGE_PID" 2>/dev/null || true
        wait "$MCP_BRIDGE_PID" 2>/dev/null || true
    fi
    rm -f "${MCP_BRIDGE_LOG:-}"
}

if [ -n "${MCP_SERVERS:-}" ]; then
    if [ "$NET_MODE" = "off" ]; then
        echo "WARNING: stdio MCP servers ignored — network is disabled (--net off)" >&2
    else
        BRIDGE_ARGS=(--deny-executable-root "$REPO_PATH")
        for _mount_entry in "${_EXTRA_MOUNT_SEEN[@]+"${_EXTRA_MOUNT_SEEN[@]}"}"; do
            if [ "${_mount_entry%%$'\t'*}" = "rw" ]; then
