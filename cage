            done

            if ! grep -q "^READY" "$MCP_BRIDGE_OUTPUT" 2>/dev/null; then
                echo "ERROR: MCP bridge failed to start" >&2
                cat "$MCP_BRIDGE_LOG" >&2
                cleanup_mcp_bridge
                rm -f "$MCP_BRIDGE_OUTPUT" "$MCP_BRIDGE_LOG"
                exit 1
            fi

            # Build JSON map and env vars for container
            CAGE_MCP_JSON="{"
            _first=1
            while IFS= read -r sline; do
                srv_name=$(echo "$sline" | sed 's/^SERVER:\(.*\)=PORT:.*/\1/')
                srv_port=$(echo "$sline" | sed 's/.*=PORT://')
                upper_name=$(echo "$srv_name" | tr '[:lower:]-' '[:upper:]_')
                MCP_BRIDGE_ARGS+=(-e "MCP_BRIDGE_PORT_${upper_name}=${srv_port}")
                [ "$_first" -eq 1 ] && _first=0 || CAGE_MCP_JSON+=","
                CAGE_MCP_JSON+="\"${srv_name}\":${srv_port}"
            done < <(grep "^SERVER:" "$MCP_BRIDGE_OUTPUT")
            CAGE_MCP_JSON+="}"

            MCP_BRIDGE_ARGS+=(
                -e "MCP_BRIDGE_HOST=host.docker.internal"
                -e "MCP_BRIDGE_TOKEN=${MCP_BRIDGE_TOKEN}"
                -e "CAGE_MCP_SERVERS=${CAGE_MCP_JSON}"
            )

            # Add host.docker.internal if netgate hasn't already
            if [ "$NET_MODE" != "gate" ]; then
                MCP_BRIDGE_ARGS+=(--add-host host.docker.internal:host-gateway)
            fi

            # If the project defines a bridged server in .mcp.json, generate a
            # private patched copy and mount it over the project file read-only
            # inside the container. Never rewrite or restore the host file: the
            # repository is container-writable, so a cleanup-time restore would
            # otherwise follow a container-controlled symlink on the host.
            if [ -e "$REPO_PATH/.mcp.json" ] || [ -L "$REPO_PATH/.mcp.json" ]; then
                MCP_PROJECT_CONFIG=$(mktemp "$CAGE_STAGE_DIR/.cage-mcp.XXXXXX")
                chmod 600 "$MCP_PROJECT_CONFIG"
                _bridged_names=()
                while IFS= read -r _server_line; do
                    _bridged_names+=("$(printf '%s\n' "$_server_line" | sed 's/^SERVER:\(.*\)=PORT:.*/\1/')")
                done < <(grep "^SERVER:" "$MCP_BRIDGE_OUTPUT")

                if python3 -I -c '
import json
import os
import stat
import sys

source, destination = sys.argv[1:3]
bridged = set(sys.argv[3:])
max_project_mcp_bytes = 16 * 1024 * 1024

try:
    before = os.lstat(source)
    if stat.S_ISLNK(before.st_mode):
        raise OSError("refusing symlinked project MCP configuration")
    if not stat.S_ISREG(before.st_mode):
        raise OSError("project MCP configuration is not a regular file")
    if before.st_size > max_project_mcp_bytes:
        raise OSError("project MCP configuration exceeds the 16 MiB limit")

    flags = os.O_RDONLY | os.O_NOFOLLOW
    descriptor = os.open(source, flags)
    opened = os.fstat(descriptor)
    current = os.lstat(source)
    identity = lambda value: (value.st_dev, value.st_ino)
    if identity(before) != identity(opened) or identity(opened) != identity(current):
        os.close(descriptor)
        raise OSError("project MCP configuration changed while it was being read")

    with os.fdopen(descriptor, "rb") as handle:
        payload_bytes = handle.read(max_project_mcp_bytes + 1)
    if len(payload_bytes) > max_project_mcp_bytes:
        raise OSError("project MCP configuration exceeds the 16 MiB limit")
    payload = payload_bytes.decode("utf-8")
    config = json.loads(payload)
except (OSError, UnicodeError, json.JSONDecodeError, RecursionError) as exc:
    sys.stderr.write("cage: cannot generate project .mcp.json overlay: %s\n" % exc)
    sys.exit(2)

if not isinstance(config, dict):
    sys.stderr.write("cage: cannot generate project .mcp.json overlay: root must be an object\n")
    sys.exit(2)

servers = config.get("mcpServers", {})
if not isinstance(servers, dict):
    sys.stderr.write("cage: cannot generate project .mcp.json overlay: mcpServers must be an object\n")
    sys.exit(2)

changed = False
for name in list(servers):
    if name in bridged:
        servers[name] = {"type": "stdio", "command": "mcp-relay", "args": [name]}
        changed = True

if not changed:
    sys.exit(3)

try:
    destination_before = os.lstat(destination)
    if not stat.S_ISREG(destination_before.st_mode):
        raise OSError("generated MCP destination is not a regular file")
    destination_flags = os.O_WRONLY | os.O_NOFOLLOW
    destination_descriptor = os.open(destination, destination_flags)
    destination_opened = os.fstat(destination_descriptor)
    destination_current = os.lstat(destination)
    if (
        identity(destination_before) != identity(destination_opened)
        or identity(destination_opened) != identity(destination_current)
    ):
        os.close(destination_descriptor)
        raise OSError("generated MCP destination changed while it was being opened")
    os.ftruncate(destination_descriptor, 0)
    with os.fdopen(destination_descriptor, "w", encoding="utf-8") as handle:
        json.dump(config, handle, indent=4)
except OSError as exc:
    sys.stderr.write("cage: cannot write project .mcp.json overlay: %s\n" % exc)
    sys.exit(2)
' "$REPO_PATH/.mcp.json" "$MCP_PROJECT_CONFIG" "${_bridged_names[@]}"; then
                    # A nested read-only bind masks only .mcp.json in the
                    # container; the surrounding repository remains writable.
                    MCP_BRIDGE_ARGS+=(-v "${MCP_PROJECT_CONFIG}:${REPO_PATH}/.mcp.json:ro")
                else
                    _overlay_status=$?
                    rm -f "$MCP_PROJECT_CONFIG"
                    MCP_PROJECT_CONFIG=""
                    if [ "$_overlay_status" -ne 3 ]; then
                        cleanup_mcp_bridge
                        rm -f "$MCP_BRIDGE_OUTPUT"
                        exit "$_overlay_status"
                    fi
                fi
            fi

            rm -f "$MCP_BRIDGE_OUTPUT"

            MCP_LABEL=" [MCP]"

            trap 'cleanup_mcp_bridge; cleanup_proxy' EXIT
        fi
    fi
fi

if [ -n "${CAGE_REMOTE_MCP_SERVERS:-}" ] && [ -z "$MCP_LABEL" ]; then
    MCP_LABEL=" [MCP]"
