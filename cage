            fi
        done
        for _bridge_env_name in $EXTRA_ENV; do
            BRIDGE_ARGS+=(--pass-env "$_bridge_env_name")
        done
        while IFS= read -r line; do
            line="$(_trim_preserving_quotes "$line")"
            [ -z "$line" ] && continue
            srv_name="${line%%=*}"
            srv_cmd="${line#*=}"
            BRIDGE_ARGS+=(--server "$srv_name" "$srv_cmd")
        done <<< "${MCP_SERVERS}"

        if [ ${#BRIDGE_ARGS[@]} -gt 0 ]; then
            MCP_BRIDGE_OUTPUT=$(mktemp)
            MCP_BRIDGE_LOG=$(mktemp)
            MCP_BRIDGE_TOKEN="$(python3 -I -c 'import secrets; print(secrets.token_hex(32))')"
            CAGE_BRIDGE_AUTH_TOKEN="$MCP_BRIDGE_TOKEN" \
                python3 -I "$SCRIPT_DIR/mcp-bridge.py" "${BRIDGE_ARGS[@]}" \
                > "$MCP_BRIDGE_OUTPUT" 2>"$MCP_BRIDGE_LOG" &
            MCP_BRIDGE_PID=$!
            # Install cleanup immediately so interrupts during startup cannot
            # strand the host bridge or its generated overlay.
            trap 'cleanup_mcp_bridge; cleanup_proxy' EXIT

            for _ in $(seq 1 30); do
                if grep -q "^READY" "$MCP_BRIDGE_OUTPUT" 2>/dev/null; then break; fi
