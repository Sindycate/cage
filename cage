        ],
        "apply",
    )


def read_manifest(stage):
    blob = read_regular(
        os.path.join(stage, "manifest.json"),
        MAX_STATE_BYTES,
        "OAuth export manifest",
        missing_ok=False,
    )
    manifest = parse_object(blob["raw"], "OAuth export manifest")
    if set(manifest) != {"credentials", "state"}:
        raise SyncError("OAuth export manifest has an unsupported schema")
    for key in ("credentials", "state"):
        entry = manifest[key]
        if not isinstance(entry, dict) or set(entry) != {"exists", "raw_sha256", "mode"}:
            raise SyncError("OAuth export manifest has an unsupported entry")
        if not isinstance(entry["exists"], bool):
            raise SyncError("OAuth export manifest has an invalid existence flag")
        if entry["exists"]:
            if not isinstance(entry["raw_sha256"], str) or not HASH_RE.fullmatch(entry["raw_sha256"]):
                raise SyncError("OAuth export manifest has an invalid hash")
            if not isinstance(entry["mode"], int):
                raise SyncError("OAuth export manifest has an invalid mode")
        elif entry["raw_sha256"] is not None or entry["mode"] is not None:
            raise SyncError("OAuth export manifest has inconsistent missing-file data")
    return manifest


def verify_export(stage, manifest):
    credential = credential_blob(
        os.path.join(stage, "credentials.raw"),
        "volume OAuth credentials",
        missing_ok=not manifest["credentials"]["exists"],
    )
    state = state_blob(
        os.path.join(stage, "state.raw"),
        "volume OAuth sync state",
        missing_ok=not manifest["state"]["exists"],
    )
    for key, blob in (("credentials", credential), ("state", state)):
        if manifest[key]["exists"] != (blob is not None):
            raise SyncError("OAuth export helper returned inconsistent files")
        if blob is not None and manifest[key]["raw_sha256"] != blob["raw_hash"]:
            raise SyncError("OAuth export helper returned inconsistent content")
        if blob is not None:
            blob["source_mode"] = manifest[key]["mode"]
    return credential, state


def ensure_host_unchanged(path, observed):
    current = credential_blob(path, "host OAuth credentials", missing_ok=observed is None)
    if (current is None) != (observed is None):
        raise SyncError("host OAuth credentials changed during reconciliation")
    if current is not None and (
        current["raw_hash"] != observed["raw_hash"]
        or current["fingerprint"] != observed["fingerprint"]
    ):
        raise SyncError("host OAuth credentials changed during reconciliation")


def atomic_host_write(path, data, observed):
    ensure_host_unchanged(path, observed)
    directory = os.path.dirname(path)
    descriptor = None
    temporary = None
    try:
        descriptor, temporary = tempfile.mkstemp(prefix=".credentials.json.cage-", dir=directory)
        os.fchmod(descriptor, 0o600)
        with os.fdopen(descriptor, "wb", closefd=False) as handle:
            handle.write(data)
            handle.flush()
            os.fsync(handle.fileno())
        ensure_host_unchanged(path, observed)
        os.replace(temporary, path)
        temporary = None
        directory_fd = os.open(directory, os.O_RDONLY | os.O_DIRECTORY)
        try:
            os.fsync(directory_fd)
        finally:
            os.close(directory_fd)
    finally:
        if descriptor is not None:
            os.close(descriptor)
        if temporary is not None:
            try:
                os.unlink(temporary)
            except FileNotFoundError:
                pass


def write_stage(path, data):
    descriptor = os.open(
        path,
        os.O_WRONLY | os.O_CREAT | os.O_EXCL | getattr(os, "O_NOFOLLOW", 0),
        0o600,
    )
    try:
        with os.fdopen(descriptor, "wb", closefd=False) as handle:
            handle.write(data)
            handle.flush()
            os.fsync(handle.fileno())
    finally:
        os.close(descriptor)


try:
    host_directory = os.path.realpath(os.path.abspath(HOST_DIR_ARG))
    checked_directory(host_directory, "host Codex directory")
    host_path = os.path.join(host_directory, ".credentials.json")
    identity = sha256(b"cage-codex-oauth-v1\0" + os.fsencode(host_directory))

    config_directory = os.path.realpath(os.path.abspath(CONFIG_DIR_ARG))
    checked_directory(config_directory, "Cage config directory")
    lock_directory = os.path.join(config_directory, "oauth-locks")
    checked_directory(lock_directory, "OAuth lock directory", create=True)
    lock_names = sorted(
        {
            "identity-" + identity + ".lock",
            "volume-" + sha256(VOLUME_NAME.encode("utf-8")) + ".lock",
        }
    )

    with contextlib.ExitStack() as stack:
        for name in lock_names:
            descriptor = acquire_lock(os.path.join(lock_directory, name))
            stack.callback(os.close, descriptor)

        host = credential_blob(
            host_path,
            "host OAuth credentials",
            normalize_mode=True,
            missing_ok=True,
        )
        # macOS exposes its system temporary directory through /var/folders,
        # which Docker Desktop and Colima may not share with their VM. Stage
        # under the already validated user config directory instead: normal
        # Cage launches require that home-backed path to be Docker-shareable.
        with tempfile.TemporaryDirectory(
            prefix=".cage-oauth-sync-",
            dir=config_directory,
        ) as stage:
            os.chmod(stage, 0o700)
            export_volume(stage)
            manifest = read_manifest(stage)
            volume, state = verify_export(stage, manifest)

            same_identity = state is not None and state["value"]["identity"] == identity
            if not same_identity:
                if state is not None:
                    print(
                        "cage: Codex OAuth state identity changed; resetting it from "
                        "the selected host Codex directory",
                        file=sys.stderr,
                    )
                desired = host
                previous_revision = 0
            else:
                previous_revision = state["value"]["revision"]
                base = state["value"]["base_sha256"]
                host_hash = host["hash"] if host is not None else None
                volume_hash = volume["hash"] if volume is not None else None

                # The host controls credential existence. This means an explicit
                # host logout removes the volume copy, while a container-side
                # deletion cannot silently log the host out.
                if host is None:
                    desired = None
                elif volume is None:
                    desired = host
                elif host_hash == volume_hash:
                    desired = host
                else:
                    host_changed = host_hash != base
                    volume_changed = volume_hash != base
                    if host_changed and volume_changed:
                        raise SyncError(
                            "OAuth credential conflict: host and volume both changed; "
                            "neither copy was overwritten"
                        )
                    if volume_changed:
                        desired = volume
                        atomic_host_write(host_path, desired["canonical"], host)
                        host = credential_blob(
                            host_path,
                            "host OAuth credentials",
                            normalize_mode=True,
                            missing_ok=False,
                        )
                    else:
                        desired = host

            desired_hash = desired["hash"] if desired is not None else None
            volume_hash = volume["hash"] if volume is not None else None
            state_core_matches = (
                same_identity
                and state["value"]["base_sha256"] == desired_hash
            )
            credential_matches = (
                (volume is None) == (desired is None)
                and (volume is None or volume_hash == desired_hash)
            )
            credential_mode_ok = volume is None or volume["source_mode"] == 0o600
            state_mode_ok = state is not None and state["source_mode"] == 0o600
            apply_needed = not (
                state_core_matches
                and credential_matches
                and credential_mode_ok
                and state_mode_ok
            )

            if apply_needed:
                revision = previous_revision + 1 if same_identity else 1
                desired_state = {
                    "version": 1,
                    "identity": identity,
                    "base_sha256": desired_hash,
                    "revision": revision,
                }
                write_stage(os.path.join(stage, "state.json"), canonical_json(desired_state))
                if desired is not None:
                    write_stage(
                        os.path.join(stage, "credentials.json"),
                        desired["canonical"],
                    )
                apply_volume(stage, manifest, desired)
except (SyncError, OSError, ValueError) as exc:
    print(f"ERROR: Codex OAuth credential sync failed: {exc}", file=sys.stderr)
    sys.exit(1)
PY
}

cleanup_cage_runtime() {
    local original_status=$? oauth_status=0
    trap - EXIT
    set +e
    sync_codex_oauth_credentials
    oauth_status=$?
    cleanup_session_sync
    cleanup_host_cmd_bridge
    cleanup_mcp_bridge
    cleanup_proxy
    if [ "$original_status" -ne 0 ]; then
        exit "$original_status"
    fi
    exit "$oauth_status"
}

sync_codex_oauth_credentials

echo "=== ${TOOL_DISPLAY_NAME} Container${YOLO_LABEL}${NET_LABEL}${MCP_LABEL}${HOST_CMD_LABEL} ==="
echo "  Repo:      $REPO_PATH"
[ -n "${CAGE_PRESET:-}" ] && echo "  Preset:    $CAGE_PRESET"
echo "  Container: $CONTAINER_NAME${PARALLEL_LABEL}"
echo "  Volume:    $VOLUME_NAME"
echo "=============================="

# Shared Docker args
DOCKER_ARGS=(
    --rm
    -it
    --name "$CONTAINER_NAME"
    --hostname "$CONTAINER_NAME"
    --cap-drop ALL
    --cap-add CHOWN
    --cap-add DAC_OVERRIDE
    --cap-add SETGID
    --cap-add SETUID
    --tmpfs /tmp
    --tmpfs /run
    -v "$REPO_PATH:$REPO_PATH"
    -e "WORKSPACE_DIR=$REPO_PATH"
    -e "HOST_UID=$(id -u)"
    -e "HOST_GID=$(id -g)"
)

# Forward terminal capability hints from host (cosmetic only)
if [ -n "${TERM:-}" ]; then
    DOCKER_ARGS+=(-e "TERM=$TERM")
fi
if [ -n "${COLORTERM:-}" ]; then
    DOCKER_ARGS+=(-e "COLORTERM=$COLORTERM")
fi

# Tool-specific Docker args
case "$CAGE_TOOL" in
    claude)
        DOCKER_ARGS+=(
            --security-opt apparmor=unconfined
            --security-opt seccomp=unconfined
            -v "$VOLUME_NAME:${CONTAINER_HOME}/.claude"
            -v "$HOST_CLAUDE_DIR:/host-claude:ro"
        )
        # Host ~/.claude.json holds user/local-scope MCP servers (the file Claude
        # actually reads MCP config from — settings.json does not carry mcpServers).
        # Mount read-only at a separate path; the entrypoint copies ONLY the
        # mcpServers key into the writable volume copy, never writing back here.
        if [ -f "$HOME/.claude.json" ]; then
            DOCKER_ARGS+=(-v "$HOME/.claude.json:/host-claude-json:ro")
        fi
        # ccstatusline keeps its own config separate from settings.json
        CCSL_HOST_PATH="$HOME/.config/ccstatusline"
        if [ -d "$CCSL_HOST_PATH" ]; then
            DOCKER_ARGS+=(-v "$CCSL_HOST_PATH:/host-ccstatusline:ro")
        fi
        # Auth: bedrock (default) or api-key
        case "${CLAUDE_AUTH:-bedrock}" in
            bedrock)
                DOCKER_ARGS+=(
                    -e "CLAUDE_CODE_USE_BEDROCK=1"
                    -e "AWS_PROFILE=${AWS_PROFILE:-}"
                    -e "AWS_REGION=${AWS_REGION:-}"
                    -v "$AWS_CREDS:${CONTAINER_HOME}/.aws/credentials:ro"
                )
                ;;
            api-key)
                if [ -z "${ANTHROPIC_API_KEY:-}" ]; then
                    echo "ERROR: CLAUDE_AUTH=api-key but ANTHROPIC_API_KEY is not set" >&2
                    exit 1
                fi
                DOCKER_ARGS+=(-e "ANTHROPIC_API_KEY=$ANTHROPIC_API_KEY")
                ;;
            *)
                echo "Invalid CLAUDE_AUTH: $CLAUDE_AUTH (use 'bedrock' or 'api-key')" >&2
                exit 1
                ;;
        esac
        ;;
    codex)
        DOCKER_ARGS+=(
            # Codex CLI uses bubblewrap to sandbox tool calls (apply_patch, rg, etc).
            # bwrap needs user namespaces, which Docker's seccomp/AppArmor block by default.
            # The container itself is the security boundary, so this is safe to relax.
            --security-opt apparmor=unconfined
            --security-opt seccomp=unconfined
            -v "$VOLUME_NAME:${CONTAINER_HOME}/.codex"
        )
        if [ -d "$CODEX_HOST_PATH" ]; then
            DOCKER_ARGS+=(-v "$CODEX_HOST_PATH:/host-codex:ro")
        fi
        if [ -n "${SKILL_MOUNTS:-}" ]; then
            CAGE_SKILL_NAMES=()
            while IFS= read -r line; do
                [ -z "$line" ] && continue
                skill_name="${line%%=*}"
                skill_path="${line#*=}"
                if [ ! -d "$skill_path" ]; then
                    echo "ERROR: selected skill '$skill_name' directory does not exist: $skill_path" >&2
                    exit 1
                fi
                if [ ! -f "$skill_path/SKILL.md" ]; then
                    echo "ERROR: selected skill '$skill_name' is missing SKILL.md: $skill_path" >&2
                    exit 1
                fi
                DOCKER_ARGS+=(-v "$skill_path:/host-agent-skills/$skill_name:ro")
                CAGE_SKILL_NAMES+=("$skill_name")
            done <<< "${SKILL_MOUNTS}"
            if [ ${#CAGE_SKILL_NAMES[@]} -gt 0 ]; then
                DOCKER_ARGS+=(-e "CAGE_SKILL_NAMES=${CAGE_SKILL_NAMES[*]}")
            fi
        else
            AGENTS_HOST_PATH="${HOST_AGENTS_DIR:-$HOME/.agents}"
            AGENTS_HOST_PATH="${AGENTS_HOST_PATH/#\~/$HOME}"
            if [ -d "$AGENTS_HOST_PATH" ]; then
                DOCKER_ARGS+=(-v "$AGENTS_HOST_PATH:/host-agents:ro")
            fi
        fi
        if [ -n "${OPENAI_API_KEY:-}" ]; then
            DOCKER_ARGS+=(-e "OPENAI_API_KEY=$OPENAI_API_KEY")
        fi
        if [ "${CODEX_COPY_AUTH:-1}" = "0" ]; then
            DOCKER_ARGS+=(-e "CODEX_COPY_AUTH=0")
        fi
        ;;
esac

# Git/SSH mounts and env vars from resolved config
if [ -n "$GIT_USER_NAME" ]; then
    DOCKER_ARGS+=(-e "GIT_USER_NAME=$GIT_USER_NAME")
fi
if [ -n "$GIT_USER_EMAIL" ]; then
    DOCKER_ARGS+=(-e "GIT_USER_EMAIL=$GIT_USER_EMAIL")
fi
if [ -n "$SSH_KEY" ]; then
    SSH_KEY_PATH="${SSH_KEY/#\~/$HOME}"
    if [ -f "$SSH_KEY_PATH" ]; then
        DOCKER_ARGS+=(-v "$SSH_KEY_PATH:${CONTAINER_HOME}/.ssh/id:ro")
        DOCKER_ARGS+=(-e 'GIT_SSH_COMMAND=ssh -i '"${CONTAINER_HOME}"'/.ssh/id -o IdentitiesOnly=yes -o StrictHostKeyChecking=accept-new')
        [ -f "$HOME/.ssh/known_hosts" ] && DOCKER_ARGS+=(-v "$HOME/.ssh/known_hosts:${CONTAINER_HOME}/.ssh/known_hosts:ro")
    fi
fi
if [ -n "$SSH_HOST" ]; then
    DOCKER_ARGS+=(-e "SSH_HOST=$SSH_HOST")
fi

# Extra env vars from resolved config
for varname in $EXTRA_ENV; do
    if [ -n "${!varname:-}" ]; then
        DOCKER_ARGS+=(-e "$varname=${!varname}")
    fi
done

if [ -n "${CAGE_REMOTE_MCP_SERVERS:-}" ]; then
    DOCKER_ARGS+=(-e "CAGE_REMOTE_MCP_SERVERS=$CAGE_REMOTE_MCP_SERVERS")
fi

# GitHub CLI auth from resolved config
if [ "${GH_AUTH:-0}" = "1" ]; then
    HOST_GH_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/gh"
    if [ -d "$HOST_GH_DIR" ]; then
        DOCKER_ARGS+=(-v "$HOST_GH_DIR:/host-gh:ro")
    fi

    # Auto-extract token from host gh if no explicit token
    if [ -z "${GH_TOKEN:-}" ] && [ -z "${GITHUB_TOKEN:-}" ]; then
        if command -v gh &>/dev/null; then
            if [ -n "${GH_ACCOUNT:-}" ]; then
                GH_TOKEN="$(gh auth token -u "$GH_ACCOUNT" 2>/dev/null)" || true
            else
                GH_TOKEN="$(gh auth token 2>/dev/null)" || true
            fi
        fi
    fi

    if [ -n "${GH_TOKEN:-}" ]; then
        DOCKER_ARGS+=(-e "GH_TOKEN=$GH_TOKEN")
    elif [ -n "${GITHUB_TOKEN:-}" ]; then
        DOCKER_ARGS+=(-e "GH_TOKEN=$GITHUB_TOKEN")
    fi
fi

[[ ${#PROXY_ARGS[@]} -gt 0 ]] && DOCKER_ARGS+=("${PROXY_ARGS[@]}")
[[ ${#MCP_BRIDGE_ARGS[@]} -gt 0 ]] && DOCKER_ARGS+=("${MCP_BRIDGE_ARGS[@]}")
[[ ${#HOST_CMD_BRIDGE_ARGS[@]} -gt 0 ]] && DOCKER_ARGS+=("${HOST_CMD_BRIDGE_ARGS[@]}")
[[ ${#EXTRA_MOUNT_ARGS[@]} -gt 0 ]] && DOCKER_ARGS+=("${EXTRA_MOUNT_ARGS[@]}")

TOOL_ARGS=()
if [ "$YOLO" -eq 1 ]; then
    case "$CAGE_TOOL" in
        claude) TOOL_ARGS+=(--dangerously-skip-permissions) ;;
        codex)  TOOL_ARGS+=(--yolo)
                DOCKER_ARGS+=(-e "CAGE_YOLO=1") ;;
    esac
fi

if [ "$NET_MODE" = "gate" ] || [ -n "$MCP_BRIDGE_PID" ] || [ -n "$HOST_CMD_BRIDGE_PID" ] || [ -n "$SESSION_SLUG" ] || [ "$CODEX_OAUTH_CREDENTIALS_SYNC" = "1" ]; then
    # Cannot use exec: need cleanup traps to run via trap EXIT
    trap cleanup_cage_runtime EXIT
    docker run "${DOCKER_ARGS[@]}" "$IMAGE" ${TOOL_ARGS[@]+"${TOOL_ARGS[@]}"} "$@"
else
    exec docker run "${DOCKER_ARGS[@]}" "$IMAGE" ${TOOL_ARGS[@]+"${TOOL_ARGS[@]}"} "$@"
fi
